# ─────────────────────────────────────────────
# MalawiEduHub — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to Git
# ─────────────────────────────────────────────

# Server
PORT=4000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=malawieduhub
DB_USER=postgres
DB_PASSWORD=yourpassword

# JWT
JWT_SECRET=change_this_to_a_long_random_string_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=another_long_random_string_for_refresh_tokens
JWT_REFRESH_EXPIRES_IN=30d

# AWS S3 (or use Cloudinary instead)
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=af-south-1
AWS_S3_BUCKET=malawieduhub-files

# Paychangu (Malawian payment gateway)
PAYCHANGU_SECRET_KEY=your_paychangu_secret
PAYCHANGU_PUBLIC_KEY=your_paychangu_public
PAYCHANGU_BASE_URL=https://api.paychangu.com

# Africa's Talking (SMS for OTP)
AT_USERNAME=your_at_username
AT_API_KEY=your_at_api_key
AT_SENDER_ID=EduHub

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Duplicate detection thresholds
DUP_CONTENT_REJECT_THRESHOLD=0.90
DUP_CONTENT_FLAG_THRESHOLD=0.75
